GMAIL_ADDRESS=your.email@gmail.com
GMAIL_APP_PASSWORD=your-app-password-here
ADMIN_EMAIL=your.email@gmail.com
PUBLIC_DOMAIN=invites.yourdomain.com
SECRET_KEY=change-this-to-a-random-string

# Server ports (defaults: admin=5001, public=8080)
ADMIN_PORT=5001
PUBLIC_PORT=8080

# Admin host/IP for dashboard links in notification emails (default: localhost)
# Set to the local IP of the machine running the app (e.g. 192.168.1.50)
ADMIN_HOST=localhost

# Secondary Gmail account (optional - allows choosing sender per event)
# GMAIL_ADDRESS_2=second.email@gmail.com
# GMAIL_APP_PASSWORD_2=second-app-password

# Android SMS Gateway (optional - only needed for SMS invitations)
# Install the "SMS Gateway" app on a spare Android phone, then enter credentials below
SMS_GATEWAY_URL=http://192.168.1.100:8080
SMS_GATEWAY_LOGIN=admin
SMS_GATEWAY_PASSWORD=your-gateway-password

# Secondary SMS Gateway (optional - allows choosing gateway per event)
# SMS_GATEWAY_URL_2=http://192.168.1.101:8080
# SMS_GATEWAY_LOGIN_2=admin
# SMS_GATEWAY_PASSWORD_2=second-gateway-password

# Backup settings (optional - SMB/CIFS mount to Synology NAS)
# Requires: sudo apt install cifs-utils
BACKUP_NAS_HOST=192.168.1.30
BACKUP_NAS_USER=pi_backup
BACKUP_NAS_PASSWORD=your-nas-password
BACKUP_NAS_SHARE=Documents
BACKUP_NAS_FOLDER=Dokumente/Backups$/invitation-app
BACKUP_KEEP_DAYS=30
